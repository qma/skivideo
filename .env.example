PORT=4173
DATA_DIR=data
SHAREPOINT_ROOT_URL=https://alterramtnco.sharepoint.com/:f:/s/TeamPalisadesTahoeShared/IgCyzteAf9SbQ4aGoEO1VqmZAWP2Px2acNgFwKn3reHavTs?e=FYefRv

# Microsoft Graph access. Prefer GRAPH_ACCESS_TOKEN for initial local testing.
GRAPH_ACCESS_TOKEN=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# OpenAI transcription and labeling.
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_LABEL_MODEL=gpt-4o-mini

# Transcription configuration. Default size is medium.
# Choices: tiny, base, small, medium, large-v1, large-v2, large-v3.
WHISPER_MODEL_SIZE=medium

# Choices: whisper.cpp (default), mlx, openai.
WHISPER_BACKEND=whisper.cpp

# Set to 1 or true to disable GPU/Metal acceleration for whisper.cpp.
WHISPER_CPP_NO_GPU=

# Metadata backend. Default local JSON is data/index/store.json.
# Set METADATA_BACKEND=firebase to sync lean metadata to Firestore.
METADATA_BACKEND=local
FIREBASE_PROJECT_ID=
FIREBASE_DATABASE_ID=(default)
FIREBASE_COLLECTION_PREFIX=skiVideoCompanion
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=
